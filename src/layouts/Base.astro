---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  /** noindex: true per la thank-you page */
  noindex?: boolean;
}

const {
  title = 'SWAPA — Prenota il tuo test drive a Milano',
  description = "L'icona elettrica di Milano. Un'ora al volante, senza impegno. Ti aspettiamo a Paderno, a due passi da Milano.",
  noindex = false,
} = Astro.props;

// URL assoluti per OG (richiesti da molti scraper social: FB, WhatsApp).
// Dominio fisso noto come base: in SSR su Vercel né Astro.url (host=localhost) né
// l'header Host si sono rivelati affidabili a runtime, quindi ancoriamo al dominio
// di produzione. Se in futuro il dominio cambia, aggiornare SITE_ORIGIN.
const SITE_ORIGIN = 'https://testdrive.swapa.it';
const ogImage = `${SITE_ORIGIN}/images/hero-share.png`;
const ogUrl = new URL(Astro.url.pathname, SITE_ORIGIN).href;
---

<!doctype html>
<html lang="it" class="bg-ink">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Verifica dominio Meta (Facebook Business) -->
    <meta name="facebook-domain-verification" content="tmnk8joxe1ln7g6i6zc13c1zjq1992" />
    <link rel="icon" type="image/png" href="/images/logo-swapa.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={ogUrl} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Poppins (vedi §3) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;700;800;900&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
