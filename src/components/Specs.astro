---
// Striscia "numeri chiave" — dati ufficiali (swapa.it/swapa-zip).
// Pochi numeri, taglio editoriale premium: danno sostanza senza scheda tecnica affollata.
// Vincoli brief: nessun prezzo, nessun confronto con altri veicoli.
const stats = [
  { value: '100', unit: 'km', label: 'di autonomia in città' },
  { value: '3,5', unit: 'h', label: 'per la ricarica completa' },
  { value: '2', unit: 'batterie', label: 'estraibili: ricarichi anche in casa' },
  { value: '2', unit: 'posti', label: 'comodi, configurazione One+1' },
];
---
<section id="numeri" class="bg-ink px-6 py-10 md:px-10 md:py-12">
  <div class="mx-auto max-w-content">
    <dl class="grid grid-cols-2 gap-px overflow-hidden rounded-2xl border border-white/10 bg-white/10 md:grid-cols-4">
      {stats.map((s) => (
        <div class="bg-ink px-4 py-5 text-center">
          <dt class="flex items-baseline justify-center gap-1.5">
            <span class="text-2xl font-900 leading-none text-accent md:text-3xl">{s.value}</span>
            <span class="text-xs font-500 uppercase tracking-wide text-white/70">{s.unit}</span>
          </dt>
          <dd class="mx-auto mt-1.5 max-w-[14rem] text-xs font-300 leading-snug text-white/55">
            {s.label}
          </dd>
        </div>
      ))}
    </dl>
  </div>
</section>
