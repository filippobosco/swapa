---
// Header minimale: logo a sinistra, micro-tagline a destra.
// Nessun link di navigazione (vedi §1/§4). La CTA scrolla al form.
---
<header class="absolute inset-x-0 top-0 z-30">
  <div class="mx-auto flex max-w-content items-center justify-between px-6 py-5 md:px-10">
    <a href="#hero" aria-label="SWAPA — torna su" class="shrink-0">
      <img
        src="/images/logo-swapa.png"
        alt="SWAPA"
        width="563"
        height="329"
        class="h-9 w-auto md:h-10"
      />
    </a>
    <span class="hidden text-[0.7rem] font-500 uppercase tracking-widest2 text-white/70 sm:block">
      Urban Electric Mobility
    </span>
  </div>
</header>
