---
// FAQ (vedi §5). DA CONFERMARE con la pagina ufficiale https://swapa.com/pages/faq.
const faqs = [
  {
    q: 'Serve la patente?',
    a: 'È un quadriciclo leggero L6e: si guida con il patentino AM (dai 14 anni, secondo normativa).',
  },
  {
    q: 'Posso entrare in Area B e Area C a Milano?',
    a: 'Sì, è 100% elettrica: accesso libero alle ZTL ambientali di Milano.',
  },
  {
    q: 'Quanto dura il test drive e quanto costa?',
    a: "Un'ora, in presenza a Paderno (Milano). È gratuito e senza impegno.",
  },
  {
    q: 'Dove si fa il test drive?',
    a: 'Paderno (Milano). Ti comunicheremo l’indirizzo esatto alla conferma del test drive.',
  },
  // Dati tecnici verificati su swapa.com/pages/faq
  {
    q: 'Quanti posti ha e quanto va veloce?',
    a: 'Due posti comodi e una velocità massima di 45 km/h: pensata per la città, non per l’autostrada.',
  },
  {
    q: 'Quanta autonomia ha?',
    a: 'Fino a 100 km con una carica: più che sufficiente per la città e l’hinterland.',
  },
  {
    q: 'Come si ricarica?',
    a: 'Le due batterie sono estraibili: le porti su e le ricarichi a casa o in ufficio, da una presa normale. Ricarica completa in circa 3,5 ore. Niente colonnine obbligatorie.',
  },
  {
    q: 'È sicura?',
    a: 'Sì. Telaio monocoque in acciaio ad alta resistenza e alluminio, costruito come un’auto vera — non un quadriciclo di plastica.',
  },
];
---
<section id="faq" class="bg-ink section-pad">
  <div class="mx-auto max-w-3xl">
    <p class="eyebrow mb-4">Domande frequenti</p>
    <h2 class="text-3xl font-800 uppercase leading-tight tracking-tight md:text-4xl">
      Tutto chiaro, prima di partire.
    </h2>

    <div class="mt-10 divide-y divide-white/10 border-y border-white/10">
      {faqs.map((f) => (
        <details class="group py-5">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-lg font-500 text-white">
            {f.q}
            <span class="shrink-0 text-accent transition-transform duration-200 group-open:rotate-45" aria-hidden="true">+</span>
          </summary>
          <p class="mt-3 max-w-2xl font-300 leading-relaxed text-white/65">{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
