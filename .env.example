# ──────────────────────────────────────────────────────────────────────────
# SWAPA — Landing test drive · variabili d'ambiente
# Copiare in `.env` per lo sviluppo locale e impostarle come env su Vercel.
# NESSUNA credenziale di CRM qui dentro: token e segreti vivono in n8n.
# ──────────────────────────────────────────────────────────────────────────

# Il lead viene inviato in parallelo a DUE destinazioni indipendenti (server-side only).
# Nessuna delle due blocca l'utente: si risponde sempre OK se la validazione passa.

# 1) Webhook n8n. n8n riceve il payload "grezzo" del sito, lo mappa sulle key Relatia
#    e fa la HTTP Request che crea il contatto su Relatia CRM.
#    PLACEHOLDER — verrà fornito (URL del nodo Webhook n8n) e impostato più avanti.
LEAD_WEBHOOK_URL=PLACEHOLDER_da_fornire

# 2) Web App Google Apps Script che fa "append row" sul foglio di controllo.
#    (Estensioni → Apps Script dal Google Sheet → Deploy → Web app → URL /exec)
#    PLACEHOLDER — verrà fornito e impostato più avanti.
SHEET_WEBHOOK_URL=PLACEHOLDER_da_fornire

# URL Calendly per il test drive (usato nella thank-you page, lato client).
PUBLIC_CALENDLY_URL=https://calendly.com/swapa-info/swapa

# ── Tracciamento (predisposto, attivato dietro consenso) ──
# Lasciare vuoto finché gli ID non sono pronti.
PUBLIC_META_PIXEL_ID=
PUBLIC_GA4_MEASUREMENT_ID=
PUBLIC_GOOGLE_ADS_ID=
